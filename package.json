    "@types/react-dom": "^19.2.0",
    "@types/node": "^22.14.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/papaparse": "^5.3.15",
    "@types/adm-zip": "^0.5.7",
    "@types/bcryptjs": "^3.0.0",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/postcss": "^4.1.0",
    "postcss": "^8.5.0",
    "vitest": "^3.1.0",
    "@playwright/test": "^1.56.0",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.3.0",
    "prettier": "^3.6.2",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=20.0.0"
