{
  "name": "kogvantage",
  "version": "0.1.0",
  "private": true,
  "description": "Kogvantage — AI-powered portfolio intelligence platform with multi-view roadmaps (Gantt + Subway), financial coordination, governance, and universal data ingestion.",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "db:seed": "tsx src/server/db/seed.ts"
  },
  "dependencies": {
    "next": "^15.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^12.4.1",
    "duckdb": "^1.2.0",
    "next-auth": "^5.0.0-beta.25",
    "@trpc/server": "^11.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/next": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@tanstack/react-query": "^5.75.0",
    "zustand": "^5.0.8",
    "date-fns": "^4.1.0",
    "papaparse": "^5.5.3",
    "uuid": "^13.0.0",
    "lucide-react": "^0.475.0",
    "adm-zip": "^0.5.16",
